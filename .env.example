# Copy to .env and fill in. .env is gitignored; this file is the committed template.

# Supabase transaction pooler (pgbouncer, port 6543) — app runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase session pooler (port 5432) — Prisma Migrate only (pgbouncer can't run DDL).
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# Supabase Storage (S3 protocol). Keep the bucket PRIVATE and restrict its
# allowed MIME types to image/jpeg + image/png (proof screenshots only).
SUPABASE_STORAGE_BUCKET="your-bucket-name"
SUPABASE_S3_ENDPOINT="https://<project-ref>.storage.supabase.co/storage/v1/s3"
SUPABASE_S3_REGION="ap-south-1"
SUPABASE_S3_ACCESS_KEY_ID=""
SUPABASE_S3_SECRET_ACCESS_KEY=""

# better-auth
BETTER_AUTH_SECRET="generate-32-random-bytes"
BETTER_AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_CLIENT_ID=""
AUTH_GOOGLE_CLIENT_SECRET=""

# Scheduled jobs (Vercel Cron sends Authorization: Bearer $CRON_SECRET)
CRON_SECRET="generate-32-random-bytes"
